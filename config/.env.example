# ─────────────────────────────────────────────────────────────────────────────
# AI Studio — environment configuration
# Copy this file to .env in the project root and fill in your values.
# Lines starting with # are comments.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
STUDIO_PORT=7860
STUDIO_HOST=0.0.0.0
# Set to "true" to create a public Gradio share link
STUDIO_SHARE=false

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=WARNING

# ── Model storage ─────────────────────────────────────────────────────────────
# Override default models directory (defaults to <project-root>/models)
# MODELS_DIR=/data/ai-studio/models

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional: set to avoid rate limits when downloading models
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Azure Speech (optional — enables Azure Neural TTS in Voice Pro) ────────────
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus

# ── Azure Translator (optional — premium translation quality) ─────────────────
# AZURE_TRANSLATOR_KEY=
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
# AZURE_TRANSLATOR_REGION=eastus

# ── Voice Pro settings ─────────────────────────────────────────────────────────
# Number of seconds allowed per process (0 = unlimited in open-source build)
VOICE_PRO_MAX_DURATION=0
# Gradio outputs folder (relative to voice-pro directory)
# VOICE_PRO_OUTPUT_DIR=outputs
